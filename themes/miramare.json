{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Miramare",
  "author": "Francisco Bach",
  "themes": [
    {
      "name": "Miramare",
      "appearance": "dark",
      "style": {
        "background": "#2A2426ff",
        "foreground": "#e6d6acff",
        "accent": "#89bebaff",
        "accents": [
          "#e68183ff",
          "#e39b7bff",
          "#d9bb80ff",
          "#87af87ff",
          "#87c095ff",
          "#89bebaff",
          "#d3a0bcff"
        ],

        "created": "#89bebaff",
        "modified": "#d9bb80ff",
        "deleted": "#e68183ff",
        "renamed": "#89bebaff",
        "conflict": "#d9bb80ff",

        "border": "#444444ff",
        "border.variant": "#242021ff",
        "border.focused": "#89bebaff",
        "border.selected": "#444444ff",
        "border.transparent": "#00000000",

        "surface.background": "#242021ff",
        "element.background": "#242021ff",
        "element.hover": "#444444ff",
        "element.active": "#444444ff",
        "element.selected": "#444444ff",

        "text": "#e6d6acff",
        "text.muted": "#787878FF",
        "text.placeholder": "#5b5b5bff",
        "text.disabled": "#5b5b5bff",
        "text.accent": "#89bebaff",

        "icon": "#e6d6acff",
        "icon.muted": "#787878FF",
        "icon.disabled": "#5b5b5bff",
        "icon.placeholder": "#5b5b5bff",
        "icon.accent": "#89bebaff",

        "editor.background": "#2A2426ff",
        "editor.foreground": "#e6d6acff",
        "editor.gutter.background": "#242021ff",
        "editor.line_number": "#5b5b5bff",
        "editor.active_line_number": "#e6d6acff",
        "editor.active_line.background": "#242021ff",
        "editor.selection.background": "#444444B3",
        "editor.invisible": "#444444ff",
        "editor.wrap_guide": "#44444433",
        "editor.active_wrap_guide": "#44444466",
        "editor.document_highlight.read_background": "#89beba26",
        "editor.document_highlight.write_background": "#d9bb8026",

        "terminal.background": "#2A2426ff",
        "terminal.foreground": "#e6d6acff",
        "terminal.bright_foreground": "#e6d6acff",
        "terminal.dim_foreground": "#5b5b5bff",
        "terminal.ansi.black": "#2A2426ff",
        "terminal.ansi.red": "#e68183ff",
        "terminal.ansi.green": "#87af87ff",
        "terminal.ansi.yellow": "#d9bb80ff",
        "terminal.ansi.blue": "#89bebaff",
        "terminal.ansi.magenta": "#d3a0bcff",
        "terminal.ansi.cyan": "#87c095ff",
        "terminal.ansi.white": "#e6d6acff",
        "terminal.ansi.bright_black": "#444444ff",
        "terminal.ansi.bright_red": "#e68183ff",
        "terminal.ansi.bright_green": "#87af87ff",
        "terminal.ansi.bright_yellow": "#d9bb80ff",
        "terminal.ansi.bright_blue": "#89bebaff",
        "terminal.ansi.bright_magenta": "#d3a0bcff",
        "terminal.ansi.bright_cyan": "#87c095ff",
        "terminal.ansi.bright_white": "#e6d6acff",

        "syntax": {
          "attribute": { "color": "#87c095ff" },
          "boolean": { "color": "#d3a0bcff" },
          "comment": { "color": "#5b5b5bff", "font_style": "italic" },
          "comment.doc": { "color": "#5b5b5bff", "font_style": "italic" },
          "constant": { "color": "#d3a0bcff" },
          "constructor": { "color": "#d9bb80ff" },
          "function": { "color": "#89bebaff" },
          "function.method": { "color": "#89bebaff" },
          "keyword": { "color": "#e68183ff" },
          "label": { "color": "#e68183ff" },
          "namespace": { "color": "#e6d6acff" },
          "number": { "color": "#d3a0bcff" },
          "operator": { "color": "#87c095ff" },
          "property": { "color": "#87c095ff" },
          "punctuation": { "color": "#e6d6acff" },
          "punctuation.bracket": { "color": "#696969FF" },
          "punctuation.delimiter": { "color": "#696969FF" },
          "string": { "color": "#87af87ff" },
          "string.escape": { "color": "#e39b7bff" },
          "tag": { "color": "#e68183ff" },
          "title": { "color": "#e39b7bff", "font_weight": 700 },
          "type": { "color": "#d9bb80ff", "font_weight": 700 },
          "variable": { "color": "#e6d6acff" },
          "variable.special": { "color": "#d9bb80ff" },
          "diff.plus": { "color": "#87af87ff" },
          "diff.minus": { "color": "#e68183ff" }
        }
      }
    }
  ]
}
